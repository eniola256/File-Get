PORT=3000
BASE_URL=http://localhost:3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
# Use "*" or a comma-separated allowlist (e.g. http://localhost:5173,http://localhost:3000)
CORS_ORIGIN=*

# MongoDB (Atlas)
# Example:
# MONGO_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/fileget?retryWrites=true&w=majority&appName=fileget-api"
# (MONGODB_URI is also supported)
MONGO_URI=

# JWT
# Generate one (PowerShell): node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
