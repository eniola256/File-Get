PORT=3000
BASE_URL=http://localhost:3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
# Comma-separated allowlist for browser frontends (no "*" in production).
# Example: http://localhost:5173,http://localhost:3000
CORS_ORIGIN=

# MongoDB (Atlas)
# Example:
# MONGO_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/fileget?retryWrites=true&w=majority&appName=fileget-api"
# (MONGODB_URI is also supported)
MONGO_URI=

# JWT
# Generate one (PowerShell): node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
